# Hugging Face model loading
APP_CLASSIFIER_HF_REPO_ID=Trinotrotolueno/app-risk-adapters
APP_CLASSIFIER_HF_TOKEN=

# Valid values:
# pdu
# ai-powered
# incentivized
APP_CLASSIFIER_LIST_MODELS=pdu,ai-powered,incentivized

# Inference
APP_CLASSIFIER_MAX_LENGTH=512
APP_CLASSIFIER_NO_4BIT=0

# Cache policy:
# keep                  -> keep loaded models resident; fastest; use for one-model workers or larger GPUs
# unload_between_models -> T4-safe all-model mode; slower because models are loaded/unloaded sequentially
# unload_after_call     -> clear after each predict_records call; debugging/constrained mode
APP_CLASSIFIER_CACHE_POLICY=keep

# Output shape
APP_CLASSIFIER_INCLUDE_PROBABILITIES=0
APP_CLASSIFIER_INCLUDE_LABEL_IDS=0
APP_CLASSIFIER_OVERWRITE_PREDICTION_ID=0

# Queue worker
QUEUE_URL=https://deepsee-queue.herokuapp.com/exchange-batch
QUEUE_API_KEY=
QUEUE_KEY=APP_CLASSIFIER_PLACEHOLDER
BATCH_SIZE=8
