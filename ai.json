import os
import random
import inspect
from typing import Dict, Optional, Tuple

import numpy as np
import pandas as pd
import torch
from datasets import Dataset
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, roc_auc_score, average_precision_score
from transformers import AutoTokenizer, AutoModelForSequenceClassification, DataCollatorWithPadding, TrainingArguments, Trainer, TrainerCallback, BitsAndBytesConfig, set_seed
from peft import LoraConfig, TaskType, get_peft_model, prepare_model_for_kbit_training

from .text import add_model_text_column
from .config import save_json


def normalize_label_binary(x, positive_labels, negative_labels):
    if x in positive_labels:
        return 1
    if x in negative_labels:
        return 0

    x_str = str(x).strip().lower()
    if x_str in {str(v).strip().lower() for v in positive_labels}:
        return 1
    if x_str in {str(v).strip().lower() for v in negative_labels}:
        return 0
    return np.nan


def prepare_multiclass_labels(d: pd.DataFrame, label_col: str):
    d = d.copy()
    d["_label_raw"] = d[label_col].copy()
    d["_label_str"] = d[label_col].fillna("").astype(str).str.strip()
    d = d[d["_label_str"] != ""].copy()

    classes = sorted(d["_label_str"].unique().tolist())
    label2id = {label: i for i, label in enumerate(classes)}
    id2label = {i: label for label, i in label2id.items()}
    d["label_id"] = d["_label_str"].map(label2id).astype(int)
    return d, label2id, id2label


def compute_metrics_binary(eval_pred):
    logits, labels = eval_pred
    probs = torch.softmax(torch.tensor(logits), dim=1).cpu().numpy()[:, 1]
    preds = (probs >= 0.5).astype(int)
    out = {}
    try:
        out["pr_auc"] = average_precision_score(labels, probs)
    except Exception:
        out["pr_auc"] = np.nan
    try:
        out["roc_auc"] = roc_auc_score(labels, probs)
    except Exception:
        out["roc_auc"] = np.nan
    out["accuracy"] = accuracy_score(labels, preds)
    out["precision"] = precision_score(labels, preds, zero_division=0)
    out["recall"] = recall_score(labels, preds, zero_division=0)
    out["f1"] = f1_score(labels, preds, zero_division=0)
    out["pred_pos_rate"] = float(preds.mean())
    return out


def compute_metrics_multiclass(eval_pred):
    logits, labels = eval_pred
    probs = torch.softmax(torch.tensor(logits), dim=1).cpu().numpy()
    preds = probs.argmax(axis=1)
    return {
        "accuracy": accuracy_score(labels, preds),
        "precision_macro": precision_score(labels, preds, average="macro", zero_division=0),
        "recall_macro": recall_score(labels, preds, average="macro", zero_division=0),
        "f1_macro": f1_score(labels, preds, average="macro", zero_division=0),
        "f1_weighted": f1_score(labels, preds, average="weighted", zero_division=0),
    }


class MetricEarlyStoppingCallback(TrainerCallback):
    def __init__(self, metric_name, patience=2, min_delta=0.0):
        self.metric_name = metric_name
        self.patience = patience
        self.min_delta = min_delta
        self.best_score = None
        self.bad_epochs = 0

    def on_evaluate(self, args, state, control, metrics=None, **kwargs):
        if metrics is None:
            return control
        current = metrics.get(self.metric_name, None)
        if current is None or np.isnan(current):
            return control
        if self.best_score is None or current > self.best_score + self.min_delta:
            self.best_score = current
            self.bad_epochs = 0
        else:
            self.bad_epochs += 1
        if self.bad_epochs >= self.patience:
            control.should_training_stop = True
        return control


def train_qlora_classifier(
    df: pd.DataFrame,
    *,
    sample_bucket_col: str = "sample_bucket",
    title_col: str = "title",
    description_col: str = "description",
    label_col: str,
    mode: str = "binary",
    model_name: str = "Qwen/Qwen2.5-3B-Instruct",
    output_dir: str = "outputs/qwen3b_qlora_app_classifier",
    seed: int = 42,
    max_length: int = 512,
    val_size: float = 0.0,
    num_train_epochs: int = 1,
    per_device_train_batch_size: int = 4,
    per_device_eval_batch_size: int = 8,
    gradient_accumulation_steps: int = 4,
    learning_rate: float = 2e-4,
    weight_decay: float = 0.01,
    warmup_steps: int = 100,
    logging_steps: int = 25,
    lora_r: int = 16,
    lora_alpha: int = 32,
    lora_dropout: float = 0.05,
    early_stopping_patience: int = 2,
    early_stopping_min_delta: float = 1e-4,
    positive_labels: Optional[set] = None,
    negative_labels: Optional[set] = None,
):
    if mode not in {"binary", "multiclass"}:
        raise ValueError("mode must be either 'binary' or 'multiclass'.")

    required_cols = [sample_bucket_col, title_col, description_col, label_col]
    missing_cols = [c for c in required_cols if c not in df.columns]
    if missing_cols:
        raise ValueError(f"Missing required columns in df: {missing_cols}")

    set_seed(seed)
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)

    work_df = df.copy()
    for c in [sample_bucket_col, title_col, description_col]:
        work_df[c] = work_df[c].fillna("").astype(str)

    if mode == "binary":
        positive_labels = positive_labels or {"rewarded_actions"}
        negative_labels = negative_labels or {"not_rewarded_actions"}
        work_df["label_bin"] = work_df[label_col].apply(lambda x: normalize_label_binary(x, positive_labels, negative_labels))
        work_df = work_df[work_df["label_bin"].isin([0, 1])].copy()
        work_df["label_bin"] = work_df["label_bin"].astype(int)
        target_col = "label_bin"
        num_labels = 2
        label2id = {str(list(negative_labels)[0]): 0, str(list(positive_labels)[0]): 1}
        id2label = {0: str(list(negative_labels)[0]), 1: str(list(positive_labels)[0])}
    else:
        work_df, label2id, id2label = prepare_multiclass_labels(work_df, label_col)
        target_col = "label_id"
        num_labels = len(label2id)
        if num_labels < 2:
            raise ValueError("Multiclass mode requires at least 2 distinct non-empty labels.")

    train_pool = work_df[work_df[sample_bucket_col] == "mined_keywords"].copy()
    test_df = work_df[work_df[sample_bucket_col] == "anchor_unbiased"].copy()

    if len(train_pool) == 0:
        raise ValueError("No rows found with sample_bucket == 'mined_keywords'.")
    if len(test_df) == 0:
        raise ValueError("No rows found with sample_bucket == 'anchor_unbiased'.")

    if mode == "multiclass":
        known_train_labels = set(train_pool[target_col].unique().tolist())
        test_df = test_df[test_df[target_col].isin(known_train_labels)].copy()
        if len(test_df) == 0:
            raise ValueError("No anchor_unbiased rows remain after restricting to multiclass labels seen in mined_keywords.")

    train_pool = add_model_text_column(train_pool, title_col=title_col, description_col=description_col)
    test_df = add_model_text_column(test_df, title_col=title_col, description_col=description_col)

    stratify_labels = train_pool[target_col] if train_pool[target_col].nunique() > 1 else None
    if val_size == 0.0:
        train_df = train_pool
        val_df = pd.DataFrame(columns=train_pool.columns)
    else:
        train_df, val_df = train_test_split(train_pool, test_size=val_size, random_state=seed, stratify=stratify_labels)

    train_ds = Dataset.from_pandas(train_df[["text", target_col]].rename(columns={target_col: "labels"}), preserve_index=False)
    val_ds = None
    if len(val_df) > 0:
        val_ds = Dataset.from_pandas(val_df[["text", target_col]].rename(columns={target_col: "labels"}), preserve_index=False)
    test_ds = Dataset.from_pandas(test_df[["text", target_col]].rename(columns={target_col: "labels"}), preserve_index=False)

    tokenizer = AutoTokenizer.from_pretrained(model_name, use_fast=True)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token

    def tokenize_function(batch):
        return tokenizer(batch["text"], truncation=True, max_length=max_length)

    train_ds = train_ds.map(tokenize_function, batched=True, remove_columns=["text"])
    if val_ds is not None:
        val_ds = val_ds.map(tokenize_function, batched=True, remove_columns=["text"])
    test_ds = test_ds.map(tokenize_function, batched=True, remove_columns=["text"])

    data_collator = DataCollatorWithPadding(tokenizer=tokenizer, pad_to_multiple_of=8 if torch.cuda.is_available() else None)
    compute_dtype = torch.bfloat16 if torch.cuda.is_available() and torch.cuda.is_bf16_supported() else torch.float16
    bnb_config = BitsAndBytesConfig(load_in_4bit=True, bnb_4bit_quant_type="nf4", bnb_4bit_use_double_quant=True, bnb_4bit_compute_dtype=compute_dtype)

    model = AutoModelForSequenceClassification.from_pretrained(
        pretrained_model_name_or_path=model_name,
        num_labels=num_labels,
        quantization_config=bnb_config,
        device_map="auto",
        torch_dtype=compute_dtype,
        id2label={int(k): v for k, v in id2label.items()},
        label2id={k: int(v) for k, v in label2id.items()},
    )
    model.config.pad_token_id = tokenizer.pad_token_id
    model.config.problem_type = "single_label_classification"
    model = prepare_model_for_kbit_training(model)
    if hasattr(model, "gradient_checkpointing_enable"):
        model.gradient_checkpointing_enable()

    lora_config = LoraConfig(
        task_type=TaskType.SEQ_CLS,
        inference_mode=False,
        r=lora_r,
        lora_alpha=lora_alpha,
        lora_dropout=lora_dropout,
        target_modules=["q_proj", "k_proj", "v_proj", "o_proj"],
    )
    model = get_peft_model(model, lora_config)

    compute_metrics = compute_metrics_binary if mode == "binary" else compute_metrics_multiclass
    early_stop_metric = "eval_pr_auc" if mode == "binary" else "eval_f1_macro"
    best_model_metric = "eval_pr_auc" if mode == "binary" else "eval_f1_macro"

    training_kwargs = dict(
        output_dir=output_dir,
        num_train_epochs=num_train_epochs,
        per_device_train_batch_size=per_device_train_batch_size,
        per_device_eval_batch_size=per_device_eval_batch_size,
        gradient_accumulation_steps=gradient_accumulation_steps,
        learning_rate=learning_rate,
        weight_decay=weight_decay,
        warmup_steps=warmup_steps,
        logging_steps=logging_steps,
        save_strategy="epoch",
        report_to="none",
        save_total_limit=2,
        fp16=torch.cuda.is_available() and not torch.cuda.is_bf16_supported(),
        bf16=torch.cuda.is_available() and torch.cuda.is_bf16_supported(),
        gradient_checkpointing=True,
        remove_unused_columns=False,
        label_names=["labels"],
    )

    ta_params = inspect.signature(TrainingArguments.__init__).parameters
    if val_size == 0.0:
        training_kwargs["load_best_model_at_end"] = False
        if "eval_strategy" in ta_params:
            training_kwargs["eval_strategy"] = "no"
        elif "evaluation_strategy" in ta_params:
            training_kwargs["evaluation_strategy"] = "no"
    else:
        training_kwargs["load_best_model_at_end"] = True
        training_kwargs["metric_for_best_model"] = best_model_metric
        training_kwargs["greater_is_better"] = True
        if "eval_strategy" in ta_params:
            training_kwargs["eval_strategy"] = "epoch"
        elif "evaluation_strategy" in ta_params:
            training_kwargs["evaluation_strategy"] = "epoch"
    if "overwrite_output_dir" in ta_params:
        training_kwargs["overwrite_output_dir"] = True

    training_args = TrainingArguments(**training_kwargs)

    trainer_kwargs = dict(model=model, args=training_args, train_dataset=train_ds, data_collator=data_collator, compute_metrics=compute_metrics)
    if val_ds is not None:
        trainer_kwargs["eval_dataset"] = val_ds

    trainer_params = inspect.signature(Trainer.__init__).parameters
    if "processing_class" in trainer_params:
        trainer_kwargs["processing_class"] = tokenizer
    else:
        trainer_kwargs["tokenizer"] = tokenizer

    trainer = Trainer(**trainer_kwargs)
    if val_ds is not None:
        trainer.add_callback(MetricEarlyStoppingCallback(metric_name=early_stop_metric, patience=early_stopping_patience, min_delta=early_stopping_min_delta))

    train_output = trainer.train()
    test_pred_results = trainer.predict(test_ds)
    test_metrics = compute_metrics((test_pred_results.predictions, test_pred_results.label_ids))

    test_logits = test_pred_results.predictions
    test_probs_all = torch.softmax(torch.tensor(test_logits), dim=1).cpu().numpy()
    test_scored = test_df.copy()

    if mode == "binary":
        test_probs = test_probs_all[:, 1]
        test_preds = (test_probs >= 0.5).astype(int)
        test_scored["pred_prob_positive"] = test_probs
        test_scored["pred_label_bin"] = test_preds
        test_scored["pred_label"] = [id2label[int(x)] for x in test_preds]
    else:
        test_pred_ids = test_probs_all.argmax(axis=1)
        test_pred_labels = pd.Series(test_pred_ids).map(id2label).values
        test_pred_conf = test_probs_all.max(axis=1)
        test_scored["pred_label_id"] = test_pred_ids
        test_scored["pred_label"] = test_pred_labels
        test_scored["pred_confidence"] = test_pred_conf
        for class_id, class_name in id2label.items():
            safe_name = str(class_name).strip().lower().replace(" ", "_").replace("/", "_").replace("-", "_")
            test_scored[f"pred_prob_{safe_name}"] = test_probs_all[:, class_id]

    os.makedirs(output_dir, exist_ok=True)
    trainer.save_model(output_dir)
    tokenizer.save_pretrained(output_dir)
    test_scored.to_csv(f"{output_dir}/anchor_unbiased_test_predictions.csv", index=False)

    save_json({"label2id": label2id, "id2label": {str(k): v for k, v in id2label.items()}}, f"{output_dir}/label_mapping.json")
    save_json({"model_name": model_name, "max_length": max_length, "mode": mode, "label_col": label_col}, f"{output_dir}/train_config.json")
    save_json(test_metrics, f"{output_dir}/test_metrics.json")

    return {
        "trainer": trainer,
        "train_output": train_output,
        "test_metrics": test_metrics,
        "test_scored": test_scored,
        "label2id": label2id,
        "id2label": id2label,
        "output_dir": output_dir,
    }
